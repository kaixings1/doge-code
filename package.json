{
  "name": "@doge-code/cli",
  "version": "999.0.0-DOGE",
  "private": true,
  "description": "Restored Claude Code source tree reconstructed from source maps.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/claude-code.git"
  },
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "bun run ./src/bootstrap-entry.ts",
    "start": "bun run ./src/bootstrap-entry.ts",
    "version": "bun run ./src/bootstrap-entry.ts --version",
    "dev:restore-check": "bun run ./src/dev-entry.ts",
    "build": "bun build --target=bun --outdir=dist ./src/bootstrap-entry.ts",
    "build:prod": "bun build --target=bun --production --outdir=dist ./src/bootstrap-entry.ts",
    "build:exe": "bun build --compile --production --outfile=dist/doge.exe ./src/bootstrap-entry.ts",
    "clean": "rimraf dist",
    "lint": "eslint . --ext .ts --fix"
  },
  "bin": {
    "doge": "./src/bootstrap-entry.ts"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "*",
    "@ant/claude-for-chrome-mcp": "file:./shims/ant-claude-for-chrome-mcp",
